int checkType(int type) {
    int types[18];
    int typeCount; 
    int i;

    /* Double Declaration of i */
    int i;

    /* Mismatch between assign expression */ 
    typeCount = true;
    typeCount = 18;

    /* Trying to assign value without indexing array */
    i = types;
    i = 0;

    while (typeCount > 0) {
        types[i] = i;
        i = i + 1;
        typeCount = typeCount - 1;
    }
    
    /* Void return when function is required to return an int */
    return ;
}

bool isEffective(int type1, int type2) {

    /* Void delcarations are not allowed for simple declarations, so it is converted to an integer declaration */
    void truth;
    truth = 1;


    /* LHS and RHS are not the same type in equality comparison */ 
    if(type1 == true) {
        type2 = 5;
        return false;
    }

    return true;
}

