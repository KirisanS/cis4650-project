void fakeFunction (int x, int y, int z) {
  
  x = y * z;

  if (x > 5) {
    y = 10;
  }

  return x;
}

void main(void) {
  int x;
  int y;
  int z[5]; 

  x = 5;
  y = 5 + 1;
  z[1] = 0; 

  fakeFunction(x, y, z[1]);

}